# M-Pesa Daraja API Configuration
# ===========================================
# Copy this file to .env and fill in your credentials
# 
# For Sandbox Testing:
# - Get credentials from https://developer.safaricom.co.ke/
# 
# For Production:
# - Get credentials from your M-Pesa integration dashboard

# Server Configuration
# ====================
SESSION_SECRET=your_secure_session_secret_here
CORS_ORIGIN=http://localhost:5173

# Safaricom Developer Portal Credentials
CONSUMER_KEY=your_consumer_key_here
CONSUMER_SECRET=your_consumer_secret_here

# Business Short Code (Provided by Safaricom)
# This is your business MPESA shortcode
SHORTCODE=your_shortcode_here

# M-Pesa Passkey
# Get this from your M-Pesa portal or developer dashboard
PASSKEY=your_passkey_here

# Callback URL
# This URL must be publicly accessible for M-Pesa callbacks
# For local development, use ngrok or similar
# Example: https://your-domain.com/api/mpesa/callback
CALLBACK_URL=http://localhost:3001/api/mpesa/callback

# ===========================================
# TESTING MODE
# ===========================================
# Use these test credentials for sandbox testing:
# 
# Test Phone: 254708374149
# Test PIN: 1234
# Test Amount: 100 KES
# 
# Note: The callback will only work with a publicly 
# accessible URL. For local testing, use ngrok:
# ngrok http 3001
# Then update CALLBACK_URL to your ngrok URL
